// contracts-service — schema 'contracts' (schema-per-service)
// Dueño de: contratos y catálogos (sociedades, áreas, plantillas).

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["contracts"]
}

enum ContractStatus {
  DRAFT
  SUBMITTED
  ADMIN_REVIEW
  LAWYER_REVIEW
  APPROVAL_PENDING
  SIGNING
  SIGNED
  REJECTED
  CANCELLED

  @@schema("contracts")
}

enum ProviderType {
  FISICA
  MORAL

  @@schema("contracts")
}

model Society {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  contracts Contract[]

  @@schema("contracts")
}

model Area {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  contracts Contract[]

  @@schema("contracts")
}

model Template {
  id        Int      @id @default(autoincrement())
  name      String
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contracts Contract[]

  @@schema("contracts")
}

model Contract {
  id           Int            @id @default(autoincrement())
  title        String
  vendorName   String
  providerType ProviderType
  status       ContractStatus @default(DRAFT)
  areaId       Int
  societyId    Int
  templateId   Int?
  createdById  Int // referencia lógica a auth.User (sin FK cross-schema)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  area     Area      @relation(fields: [areaId], references: [id])
  society  Society   @relation(fields: [societyId], references: [id])
  template Template? @relation(fields: [templateId], references: [id])

  @@schema("contracts")
}
